{
  // 选佛谱 · 十法界须弥山世界 —— Cloudflare 部署配置
  // 部署：npm run deploy（= vite build + wrangler deploy）
  "name": "xuanfopu-sumeru",
  "main": "worker/index.js",
  "compatibility_date": "2026-07-01",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS"
  },
  "durable_objects": {
    "bindings": [
      { "name": "ROOM", "class_name": "RoomDO" }
    ]
  },
  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["RoomDO"] }
  ],
  "observability": { "enabled": true }
}
